[node name="LabelTop" parent="ebox16/VBoxContainer" parent_id_path=PackedInt32Array(1729303487, 1297630833) index="0" unique_id=235651543]
text = "Low Voltage | Ebox 16"

[node name="LabelTopResisdential" parent="ebox16/VBoxContainer" parent_id_path=PackedInt32Array(1729303487, 1297630833) index="1" unique_id=1213854588]
text = "16kWh Residential Battery"

[node name="LabelDesc" parent="ebox16" index="2" unique_id=390103992]
text = "The 16kWh residential energy storage battery adopts 314Ah high-cycle cells, boasting large capacity and stable performance. It features excellent safety and a long service life, while supporting high-current discharge. Equipped with multiple application scenarios, it is widely compatible with household use, backup power and off-grid scenarios, providing reliable energy storage solutions for families."

[node name="Label2" parent="ebox16/HBoxContainer/Panel1/VBoxContainer" parent_id_path=PackedInt32Array(1729303487, 713923525) index="1" unique_id=2034832736]
text = "Up to 16 units in parallel, 16~256kWh capacity"

[node name="Label2" parent="ebox16/HBoxContainer/Panel2/VBoxContainer" parent_id_path=PackedInt32Array(1729303487, 1489062897) index="1" unique_id=728807213]
text = "High Energy Density 314Ah LFP Cells, 200A Continuous Charge/Discharge Current, and Intelligent Cell Balancing."

[node name="Label" parent="ebox16/HBoxContainer/Panel3/VBoxContainer" parent_id_path=PackedInt32Array(1729303487, 45560476) index="0" unique_id=1796206169]
text = "Easy Installation
"

[node name="Label2" parent="ebox16/HBoxContainer/Panel3/VBoxContainer" parent_id_path=PackedInt32Array(1729303487, 45560476) index="1" unique_id=387013047]
text = "Designed light and simple with built-in pulleys, it allows one-person moving and installation."

[node name="Label" parent="ebox16/HBoxContainer/Panel4/VBoxContainer" parent_id_path=PackedInt32Array(1729303487, 404412639) index="0" unique_id=1074766516]
text = "Intelligent Management
"

[node name="Label2" parent="ebox16/HBoxContainer/Panel4/VBoxContainer" parent_id_path=PackedInt32Array(1729303487, 404412639) index="1" unique_id=1621885325]
text = "Built-in WiFi for seamless remote intelligent APP monitoring and real-time management; supports APP OTA & remote firmware updates to cut after-sales costs."

