[node name="LabelTopResisdential" parent="rove/VBoxContainer" index="1" unique_id=1213854588]
text = "3.6/6.0/12.0KW Residential Off-grid Inverter"
autowrap_mode = 2

[node name="LabelDesc" parent="rove" index="2" unique_id=390103992]
text = "Off-grid inverter is a power conversion device independent of the public power grid. Its core function is to convert the electrical energy output by DC power sources such as solar panels and storage batteries into AC electrical energy that can be directly used by household appliances . It is widely used in areas without grid coverage or with unstable power grids."

[node name="Label" parent="rove/HBoxContainer/Panel1/VBoxContainer" parent_id_path=PackedInt32Array(907655103, 713923525) index="0" unique_id=881516082]
text = "Detachable Dust Coverign
"
