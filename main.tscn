[node name="Label2" parent="rove/HBoxContainer/Panel1/VBoxContainer" parent_id_path=PackedInt32Array(907655103, 713923525) index="1" unique_id=2034832736]
text = "Detachable dust cover for harsh environment,easy to replace."

