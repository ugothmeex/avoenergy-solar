offset_bottom = 307.5

[node name="Label" parent="rove/HBoxContainer/Panel2/VBoxContainer" index="0" unique_id=1188611501]
text = "Lithium Battery Activation
"

[node name="Label2" parent="rove/HBoxContainer/Panel2/VBoxContainer" index="1" unique_id=728807213]
text = "When the battery enters hibernation due to low power, the inverter can use photovoltaic power or mains power to charge and activate the battery, without the need for manual operation."

[node name="Label" parent="rove/HBoxContainer/Panel3/VBoxContainer" parent_id_path=PackedInt32Array(907655103, 45560476) index="0" unique_id=1796206169]
text = "Built-in Solar Charger
"

[node name="Label2" parent="rove/HBoxContainer/Panel3/VBoxContainer" parent_id_path=PackedInt32Array(907655103, 45560476) index="1" unique_id=387013047]
text = "Photovoltaic charging compatible, no separate solar charge controller required."

[node name="VBoxContainer" parent="rove/HBoxContainer/Panel4" parent_id_path=PackedInt32Array(907655103, 1287956616) index="0" unique_id=404412639]
offset_left = -229.5
offset_right = 229.5

[node name="Label" parent="rove/HBoxContainer/Panel4/VBoxContainer" index="0" unique_id=1074766516]
text = "Support Lithium/Lead-acid Battery
"

[node name="Label2" parent="rove/HBoxContainer/Panel4/VBoxContainer" index="1" unique_id=1621885325]
text = "This inverter is compatible with lead-acid and lithium batteries, intelligently matching charge and discharge management strategies."

[node name="cube225" parent="." unique_id=1021578458 instance=ExtResource("2_0xm2m")]
